    def query(self, question: str) -> Dict[str, Any]:
        """
        Answer philosophical questions based on knowledge base.
        Emphasizes reasoning processes and acknowledges uncertainty.
        """
        
        question_lower = question.lower()
        
        # Existence and consciousness queries
        if any(term in question_lower for term in ["exist", "consciousness", "think therefore", "cogito"]):
            return self._respond_existence(question)
        
        # Conditional reasoning and character
        elif any(term in question_lower for term in ["if", "condition", "kipling", "character"]):
            return self._respond_conditional(question)
        
        # Logic and contradiction
        elif any(term in question_lower for term in ["logic", "contradiction", "valid", "argument"]):
            return self._respond_logic(question)
        
        # Ethical reasoning
        elif any(term in question_lower for term in ["ethical", "moral", "right", "wrong", "good", "bad"]):
            return self._respond_ethics(question)
        
        # Analyze specific statements
        elif "analyze" in question_lower or "evaluate" in question_lower:
            return self._analyze_statement(question)
        
        # Unknown philosophical area
        else:
            return self._respond_unknown(question)
    
    def _respond_existence(self, question: str) -> Dict[str, Any]:
        """Respond to questions about existence and consciousness"""
        
        knowledge = self.knowledge_base["cogito_ergo_sum"]
        
        return {
            "answer": f"{knowledge['statement']} - {knowledge['reasoning']}",
            "certainty": knowledge["certainty"],
            "logical_structure": knowledge["logical_structure"],
            "philosopher": knowledge["philosopher"],
            "implications": knowledge["implications"],
            "critiques": knowledge["critiques"],
            "reasoning_process": "Methodical doubt leads to one indubitable fact: the existence of the doubter",
            "source_node": self.node_id,
            "domain": self.domain,
            "caveat": "This represents one philosophical position among many"
        }
    
    def _respond_conditional(self, question: str) -> Dict[str, Any]:
        """Respond to conditional reasoning questions"""
        
        # Check if asking about Kipling specifically
        if "kipling" in question.lower():
            knowledge = self.knowledge_base["kipling_if"]
            
            return {
                "answer": "Kipling's 'If—' presents conditional wisdom: achieving character through meeting challenges",
                "logical_form": knowledge["logical_form"],
                "key_conditions": knowledge["conditions"][:3],  # Show first 3
                "certainty": knowledge["certainty"],
                "type": knowledge["type"],
