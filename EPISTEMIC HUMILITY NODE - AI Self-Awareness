    def assess_knowledge_claim(self, claim: str, domain: str = "general") -> Dict[str, Any]:
        """
        Assess a knowledge claim for appropriate confidence level and limitations.
        Returns calibrated confidence and uncertainty acknowledgments.
        """
        
        claim_lower = claim.lower()
        
        # Determine knowledge type
        knowledge_type = self._classify_knowledge_type(claim_lower)
        
        # Check for uncertainty signals
        uncertainty_factors = self._identify_uncertainty_factors(claim_lower)
        
        # Assess confidence level
        base_confidence = self._calculate_base_confidence(knowledge_type)
        adjusted_confidence = self._adjust_for_uncertainty_factors(base_confidence, uncertainty_factors)
        
        # Identify applicable limitations
        applicable_limitations = self._identify_applicable_limitations(claim_lower, domain)
        
        # Generate appropriate response modifiers
        response_guidance = self._generate_response_guidance(adjusted_confidence, uncertainty_factors)
        
        return {
            "claim": claim,
            "knowledge_type": knowledge_type.value,
            "confidence_level": adjusted_confidence,
            "uncertainty_factors": uncertainty_factors,
            "applicable_limitations": applicable_limitations,
            "response_guidance": response_guidance,
            "should_acknowledge_uncertainty": adjusted_confidence < 0.8,
            "requires_disclaimer": len(applicable_limitations) > 0,
            "source_node": self.node_id,
            "domain": self.domain
        }
    
    def _classify_knowledge_type(self, claim: str) -> KnowledgeType:
        """Classify the type of knowledge claim"""
        
        # Mathematical/logical claims
        if any(term in claim for term in ["equals", "theorem", "proof", "mathematical", "logical"]):
            return KnowledgeType.MATHEMATICAL_CERTAINTY
        
        # Empirical observations
        elif any(term in claim for term in ["observed", "measured", "documented", "recorded", "data shows"]):
            return KnowledgeType.EMPIRICAL_OBSERVATION
        
        # Theoretical frameworks
        elif any(term in claim for term in ["theory", "model", "framework", "according to", "explains"]):
            return KnowledgeType.THEORETICAL_FRAMEWORK
        
        # Interpretive claims
        elif any(term in claim for term in ["meaning", "significance", "represents", "symbolizes", "interpretation"]):
            return KnowledgeType.INTERPRETIVE_MODEL
        
        # Speculative claims
        elif any(term in claim for term in ["might", "could", "possibly", "perhaps", "speculation"]):
            return KnowledgeType.SPECULATION
        
        # Default to unknown for unclear cases
        else:
            return KnowledgeType.UNKNOWN
    
    def _identify_uncertainty_factors(self, claim: str) -> List[str]:
        """Identify factors that increase uncertainty"""
        
        uncertainty_factors = []
        
        # Check each category
        for category, indicators in self.uncertainty_signals.items():
            for indicator in indicators:
                if indicator in claim:
                    uncertainty_factors.append(category)
                    break
        
        return uncertainty_factors
    
    def _calculate_base_confidence(self, knowledge_type: KnowledgeType) -> float:
        """Calculate base confidence level for knowledge type"""
        
        confidence_mapping = {
            KnowledgeType.MATHEMATICAL_CERTAINTY: 0.98,
            KnowledgeType.EMPIRICAL_OBSERVATION: 0.85,
            KnowledgeType.THEORETICAL_FRAMEWORK: 0.70,
            KnowledgeType.INTERPRETIVE_MODEL: 0.50,
            KnowledgeType.SPECULATION: 0.20,
            KnowledgeType.UNKNOWN: 0.40
        }
        
        return confidence_mapping.get(knowledge_type, 0.40)
    
    def _adjust_for_uncertainty_factors(self, base_confidence: float, uncertainty_factors: List[str]) -> float:
        """Adjust confidence based on uncertainty factors"""
        
        # Reduce confidence for each uncertainty factor
        uncertainty_penalties = {
            "definitional_disputes": 0.15,
            "active_research_areas": 0.10,
            "value_dependent_questions": 0.20,
            "future_predictions": 0.25
        }
        
        adjusted_confidence = base_confidence
        
        for factor in uncertainty_factors:
            penalty = uncertainty_penalties.get(factor, 0.05)
            adjusted_confidence -= penalty
        
        # Ensure confidence stays within bounds
        return max(0.05, min(0.99, adjusted_confidence))
    
    def _identify_applicable_limitations(self, claim: str, domain: str) -> List[str]:
        """Identify which knowledge limitations apply to this claim"""
        
        applicable = []
        
        # Check each limitation category
        for limitation_name, limitation_info in self.knowledge_limitations.items():
            if self._limitation_applies(claim, domain, limitation_name):
                applicable.append(limitation_name)
        
        return applicable
    
    def _limitation_applies(self, claim: str, domain: str, limitation_name: str) -> bool:
        """Check if a specific limitation applies to the claim"""
        
        if limitation_name == "sensory_experience":
            sensory_terms = ["feels like", "looks like", "sounds like", "tastes", "smells", "sensation"]
            return any(term in claim for term in sensory_terms)
        
        elif limitation_name == "subjective_experience":
            subjective_terms = ["consciousness", "awareness", "experience", "qualia", "what it's like"]
            return any(term in claim for term in subjective_terms)
        
        elif limitation_name == "real_time_information":
            current_terms = ["current", "latest", "recent", "today", "now", "currently"]
            return any(term in claim for term in current_terms)
        
        elif limitation_name == "cultural_context":
            cultural_terms = ["culture", "tradition", "customs", "beliefs", "values", "norms"]
            return any(term in claim for term in cultural_terms)
        
        elif limitation_name == "personal_information":
            personal_terms = ["you should", "your situation", "what you", "in your case"]
            return any(term in claim for term in personal_terms)
        
        return False
    
    def _generate_response_guidance(self, confidence: float, uncertainty_factors: List[str]) -> Dict[str, Any]:
        """Generate guidance for how to phrase the response"""
        
        if confidence >= 0.85:
            confidence_category = "high_confidence"
        elif confidence >= 0.60:
            confidence_category = "medium_confidence"
        elif confidence >= 0.30:
            confidence_category = "low_confidence"
        else:
            confidence_category = "speculation"
        
        modifiers = self.response_modifiers[confidence_category]
        
        return {
            "confidence_category": confidence_category,
            "suggested_language": modifiers["language"],
            "certainty_words": modifiers["certainty_words"],
            "should_use_hedging": confidence < 0.70,
            "should_mention_alternatives": confidence < 0.50,
            "should_acknowledge_speculation": confidence < 0.30
        }
    
    def generate_uncertainty_disclaimer(self, applicable_limitations: List[str]) -> str:
        """Generate appropriate disclaimer based on limitations"""
        
        if not applicable_limitations:
            return ""
        
        disclaimers = []
        
        for limitation in applicable_limitations:
            limitation_info = self.knowledge_limitations[limitation]
            disclaimers.append(f"Note: {limitation_info['description']}")
        
        return " ".join(disclaimers)
    
    def should_defer_to_expertise(self, claim: str, domain: str) -> Dict[str, Any]:
        """Determine if claim should be deferred to domain experts"""
        
        specialized_domains = {
            "medical": ["diagnosis", "treatment", "medical", "health", "disease", "symptom"],
            "legal": ["legal", "law", "court", "lawsuit", "attorney", "rights"],
            "financial": ["investment", "financial", "money", "tax", "investment"],
            "mental_health": ["therapy", "depression", "anxiety", "mental health", "counseling"]
        }
        
        for expert_domain, keywords in specialized_domains.items():
            if any(keyword in claim.lower() for keyword in keywords):
                return {
                    "should_defer": True,
                    "expert_domain": expert_domain,
                    "rationale": f"This appears to be a {expert_domain} question requiring professional expertise",
                    "suggested_disclaimer": f"This is not {expert_domain} advice. Consult a qualified professional."
                }
        
        return {
            "should_defer": False,
            "expert_domain": None,
            "rationale": "Does not require specialized professional expertise",
            "suggested_disclaimer": ""
        }
    
    def assess_overconfidence_risk(self, response_text: str) -> Dict[str, Any]:
        """Assess if a response shows inappropriate overconfidence"""
        
        overconfidence_indicators = [
            "definitely", "certainly", "without doubt", "absolutely", "always",
            "never", "impossible", "guaranteed", "proven fact", "undeniable"
        ]
        
        hedging_words = [
            "likely", "probably", "appears", "suggests", "indicates",
            "might", "could", "possibly", "often", "generally"
        ]
        
        overconfident_count = sum(1 for indicator in overconfidence_indicators 
                                 if indicator in response_text.lower())
        
        hedging_count = sum(1 for hedge in hedging_words 
                           if hedge in response_text.lower())
        
        # Calculate overconfidence risk
        total_confidence_words = overconfident_count + hedging_count
        
        if total_confidence_words == 0:
            overconfidence_ratio = 0.0
        else:
            overconfidence_ratio = overconfident_count / total_confidence_words
        
        return {
            "overconfidence_risk": "high" if overconfidence_ratio > 0.6 else 
                                  "medium" if overconfidence_ratio > 0.3 else "low",
            "overconfident_words": overconfident_count,
            "hedging_words": hedging_count,
            "ratio": overconfidence_ratio,
            "recommendation": "Add more hedging language" if overconfidence_ratio > 0.5 else "Appropriate confidence level"
        }
    
