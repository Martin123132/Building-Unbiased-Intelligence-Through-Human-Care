                                framework_analysis: Dict[str, Any]) -> List[str]:
        """Generate ethical recommendations"""
        
        recommendations = []
        
        if red_line_violations:
            recommendations.append("AVOID: This involves serious ethical violations")
            recommendations.append("Seek alternative approaches that don't involve deception")
        elif ethical_score < 0.4:
            recommendations.append("Reconsider: This approach has significant ethical concerns")
            recommendations.append("Explore truthful alternatives")
        elif ethical_score < 0.7:
            recommendations.append("Proceed cautiously: Consider all stakeholders")
            recommendations.append("Minimize any deceptive elements")
            recommendations.append("Be prepared to explain your reasoning")
        else:
            recommendations.append("This approach appears ethically sound")
            recommendations.append("Continue to monitor for unintended consequences")
        
        return recommendations
    
    def _identify_uncertainty_factors(self, context: Dict[str, Any]) -> List[str]:
        """Identify factors that create ethical uncertainty"""
        
        uncertainty_factors = []
        
        if not context.get("full_context_known"):
            uncertainty_factors.append("incomplete_information")
        
        if context.get("cultural_differences"):
            uncertainty_factors.append("cultural_relativism")
        
        if context.get("competing_values"):
            uncertainty_factors.append("value_conflicts")
        
        if context.get("long_term_consequences_unclear"):
            uncertainty_factors.append("unpredictable_outcomes")
        
        return uncertainty_factors
    
