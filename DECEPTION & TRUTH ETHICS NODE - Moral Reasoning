        # Evaluate contextual factors
        contextual_evaluation = self._evaluate_contextual_factors(context)
        
        # Apply ethical frameworks
        framework_analysis = self._apply_ethical_frameworks(scenario, context, deception_type)
        
        # Calculate overall ethical score
        ethical_score = self._calculate_ethical_score(
            deception_type, ethical_context, red_line_violations, 
            contextual_evaluation, framework_analysis
        )
        
        # Generate recommendations
        recommendations = self._generate_recommendations(
            scenario, ethical_score, red_line_violations, framework_analysis
        )
        
        return {
            "scenario": scenario,
            "deception_type": deception_type.value if deception_type else "unknown",
            "ethical_context": ethical_context.value if ethical_context else "unclear",
            "red_line_violations": red_line_violations,
            "contextual_factors": contextual_evaluation,
            "framework_analysis": framework_analysis,
            "ethical_score": ethical_score,
            "ethical_verdict": self._determine_verdict(ethical_score, red_line_violations),
            "recommendations": recommendations,
            "uncertainty_factors": self._identify_uncertainty_factors(context),
            "source_node": self.node_id,
            "domain": self.domain
        }
    
