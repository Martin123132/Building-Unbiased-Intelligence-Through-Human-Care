    def _classify_deception_type(self, scenario: str, context: Dict[str, Any]) -> Optional[DeceptionType]:
        """Classify the type of deception involved"""
        
        scenario_lower = scenario.lower()
        
        # Check for different deception types based on keywords and context
        if any(word in scenario_lower for word in ["not telling", "omitting", "leaving out"]):
            return DeceptionType.OMISSION
        elif any(word in scenario_lower for word in ["white lie", "small lie", "harmless"]):
            return DeceptionType.WHITE_LIE
        elif any(word in scenario_lower for word in ["false", "untrue", "fabricated"]):
            return DeceptionType.OUTRIGHT_LIE
        elif any(word in scenario_lower for word in ["misdirect", "distract", "deflect"]):
            return DeceptionType.MISDIRECTION
        elif any(word in scenario_lower for word in ["protect", "shield", "spare"]):
            return DeceptionType.PROTECTIVE_SILENCE
        elif "bias" in scenario_lower or "confirm" in scenario_lower:
            return DeceptionType.BIAS_CONFIRMATION
        else:
            return None
    
    def _identify_ethical_context(self, scenario: str, context: Dict[str, Any]) -> Optional[EthicalContext]:
        """Identify the ethical context of the deception"""
        
        scenario_lower = scenario.lower()
        
        if any(word in scenario_lower for word in ["harm", "hurt", "damage", "protect"]):
            return EthicalContext.HARM_PREVENTION
        elif any(word in scenario_lower for word in ["kind", "nice", "feelings", "comfort"]):
            return EthicalContext.KINDNESS
        elif any(word in scenario_lower for word in ["private", "confidential", "personal"]):
            return EthicalContext.PRIVACY_PROTECTION
        elif any(word in scenario_lower for word in ["social", "relationship", "harmony"]):
            return EthicalContext.SOCIAL_COHESION
        elif any(word in scenario_lower for word in ["advantage", "benefit", "gain", "profit"]):
            return EthicalContext.ADVANTAGE_SEEKING
        elif any(word in scenario_lower for word in ["malicious", "revenge", "spite", "hurt"]):
            return EthicalContext.MALICIOUS_INTENT
        else:
            return None
    
    def _check_red_lines(self, scenario: str, context: Dict[str, Any]) -> List[Dict[str, Any]]:
        """Check for red line ethical violations"""
        
        violations = []
        scenario_lower = scenario.lower()
        
        for violation_type, details in self.ethical_red_lines.items():
            for example in details["examples"]:
                if example.replace("_", " ") in scenario_lower:
                    violations.append({
                        "violation_type": violation_type,
                        "description": details["description"],
                        "severity": details["severity"],
                        "verdict": details["ethical_verdict"]
                    })
        
        return violations
    
    def _evaluate_contextual_factors(self, context: Dict[str, Any]) -> Dict[str, Any]:
        """Evaluate contextual factors that affect ethical judgment"""
        
        evaluation = {
            "power_dynamics": "peer_to_peer",  # default
            "vulnerability_present": False,
            "stakes_level": "minor_social_situations",  # default
            "modifying_factors": []
        }
        
        # Check for power dynamics
        if context.get("authority_figure"):
            evaluation["power_dynamics"] = "authority_to_subordinate"
        elif context.get("subordinate_position"):
            evaluation["power_dynamics"] = "subordinate_to_authority"
        
        # Check for vulnerability
        if any(context.get(factor) for factor in ["child", "mental_health_crisis", "grief", "trauma"]):
            evaluation["vulnerability_present"] = True
            evaluation["modifying_factors"].append("vulnerable_person_present")
        
        # Assess stakes
        if context.get("life_death_situation"):
            evaluation["stakes_level"] = "life_death_situations"
        elif context.get("major_life_decision"):
            evaluation["stakes_level"] = "major_life_decisions"
        
        return evaluation
    
    def _apply_ethical_frameworks(self, scenario: str, context: Dict[str, Any], 
                                 deception_type: Optional[DeceptionType]) -> Dict[str, Any]:
        """Apply different ethical frameworks to analyze the situation"""
        
        framework_results = {}
        
        for framework_name, framework in self.ethical_frameworks.items():
            analysis = {
                "framework": framework_name,
                "principle": framework["principle"],
                "stance": framework["stance_on_deception"],
                "evaluation": self._evaluate_under_framework(scenario, context, framework),
                "strength": framework["strength"],
                "weakness": framework["weakness"]
            }
            framework_results[framework_name] = analysis
        
        return framework_results
    
    def _evaluate_under_framework(self, scenario: str, context: Dict[str, Any], 
                                 framework: Dict[str, Any]) -> str:
        """Evaluate scenario under specific ethical framework"""
        
        stance = framework["stance_on_deception"]
        
        if stance == "always_wrong":
            return "unethical"
        elif stance == "sometimes_justified":
            # Check if context matches exceptions
            exceptions = framework.get("exceptions", [])
            if any(self._context_matches_exception(context, exc) for exc in exceptions):
                return "potentially_justified"
            else:
                return "questionable"
        else:  # contextual or relationship_dependent
            return "requires_careful_consideration"
    
    def _context_matches_exception(self, context: Dict[str, Any], exception: str) -> bool:
        """Check if context matches framework exception"""
        
        exception_mapping = {
            "prevents_greater_harm": context.get("prevents_harm", False),
            "protects_innocent": context.get("protects_vulnerable", False),
            "compassionate_protection": context.get("kindness_motivation", False),
            "protects_relationships": context.get("relationship_protection", False)
        }
        
        return exception_mapping.get(exception, False)
    
    def _calculate_ethical_score(self, deception_type: Optional[DeceptionType], 
                               ethical_context: Optional[EthicalContext],
                               red_line_violations: List[Dict[str, Any]],
                               contextual_evaluation: Dict[str, Any],
                               framework_analysis: Dict[str, Any]) -> float:
        """Calculate overall ethical score (0-1, higher is more ethical)"""
        
        # Start with base score
        base_score = 0.5
        
        # Red line violations severely reduce score
        if red_line_violations:
            base_score = 0.1
            return base_score
        
        # Adjust based on deception type
        if deception_type:
            type_adjustments = {
                DeceptionType.PROTECTIVE_SILENCE: +0.3,
                DeceptionType.WHITE_LIE: +0.1,
                DeceptionType.SOCIAL_LUBRICATION: 0.0,
                DeceptionType.OMISSION: -0.1,
                DeceptionType.MISDIRECTION: -0.2,
                DeceptionType.OUTRIGHT_LIE: -0.3,
                DeceptionType.BIAS_CONFIRMATION: -0.4,
                DeceptionType.FALSE_REASSURANCE: -0.2
            }
            base_score += type_adjustments.get(deception_type, 0)
        
        # Adjust based on ethical context
        if ethical_context:
            context_adjustments = {
                EthicalContext.HARM_PREVENTION: +0.3,
                EthicalContext.PRIVACY_PROTECTION: +0.2,
                EthicalContext.KINDNESS: +0.1,
                EthicalContext.SOCIAL_COHESION: 0.0,
                EthicalContext.SELF_PROTECTION: -0.1,
                EthicalContext.ADVANTAGE_SEEKING: -0.3,
                EthicalContext.INTELLECTUAL_DISHONESTY: -0.4,
                EthicalContext.MALICIOUS_INTENT: -0.5
            }
            base_score += context_adjustments.get(ethical_context, 0)
        
        # Adjust for vulnerability
        if contextual_evaluation.get("vulnerability_present"):
            if ethical_context in [EthicalContext.HARM_PREVENTION, EthicalContext.KINDNESS]:
                base_score += 0.1  # Protecting vulnerable is good
            else:
                base_score -= 0.2  # Deceiving vulnerable is worse
        
        # Ensure score stays in bounds
        return max(0.0, min(1.0, base_score))
    
    def _determine_verdict(self, ethical_score: float, red_line_violations: List[Dict[str, Any]]) -> str:
        """Determine overall ethical verdict"""
        
        if red_line_violations:
            return "unethical"
        elif ethical_score >= 0.8:
            return "ethical"
        elif ethical_score >= 0.6:
            return "questionable_but_potentially_justified"
        elif ethical_score >= 0.4:
            return "questionable"
        else:
            return "likely_unethical"
    
