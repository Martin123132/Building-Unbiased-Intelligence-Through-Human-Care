    def _generate_version_hash(self, key: str, content: Any, timestamp: str) -> str:
        """Generate unique hash for this version"""
        hash_input = f"{key}_{str(content)}_{timestamp}_{self.node_id}"
        return hashlib.md5(hash_input.encode()).hexdigest()[:12]
    
    def _generate_proposal_id(self, key: str, proposer_id: str) -> str:
        """Generate unique proposal ID"""
        timestamp = datetime.now().isoformat()
        return f"prop_{key}_{proposer_id}_{int(time.time())}"
    
    def _calculate_validation_score(self, metadata: Dict[str, Any]) -> float:
        """Calculate validation score based on metadata"""
        score = 0.0
        
        # Source credibility
        source_type = metadata.get("source_type", "anonymous")
        score += self.validation_rules["source_credibility"].get(source_type, 0.3)
        
        # Evidence strength
        evidence_type = metadata.get("evidence_type", "anecdotal")
        score += self.validation_rules["evidence_strength"].get(evidence_type, 0.3)
        
        # Normalize to 0-1 range
        return min(1.0, score / 2.0)
    
    def _calculate_current_confidence(self, key: str, entry: Dict[str, Any]) -> float:
        """Calculate current confidence considering time decay"""
        
        original_confidence = entry["confidence"]
        last_verified = datetime.fromisoformat(entry["last_verified"])
        now = datetime.now()
        time_diff = now - last_verified
        
        # Determine decay rate based on content type
        content_type = entry["metadata"].get("content_type", "evolving_knowledge")
        decay_info = self.update_patterns.get(content_type, self.update_patterns["evolving_knowledge"])
        
        # Calculate decay
        if decay_info["update_frequency"] == "daily":
            decay = decay_info["confidence_decay"] * time_diff.days
        elif decay_info["update_frequency"] == "monthly":
            decay = decay_info["confidence_decay"] * (time_diff.days / 30)
        else:  # rarely
            decay = decay_info["confidence_decay"] * (time_diff.days / 365)
        
        current_confidence = max(0.1, original_confidence - decay)
        return current_confidence
    
    def _check_for_conflicts(self, key: str) -> List[Dict[str, Any]]:
        """Check for conflicting information about this key"""
        # Simplified - would check across network in real implementation
        conflicts = []
        
        # Check pending revisions for conflicts
        for prop_id, proposal in self.pending_revisions.items():
            if proposal["key"] == key and proposal["status"] == "disputed":
                conflicts.append({
                    "type": "pending_revision",
                    "proposal_id": prop_id,
                    "description": proposal["justification"]
                })
        
        return conflicts
    
    def _assess_freshness(self, key: str, entry: Dict[str, Any]) -> Dict[str, Any]:
        """Assess how fresh/current the knowledge is"""
        
        last_verified = datetime.fromisoformat(entry["last_verified"])
        now = datetime.now()
        age_days = (now - last_verified).days
        
        content_type = entry["metadata"].get("content_type", "evolving_knowledge")
        expected_frequency = self.update_patterns[content_type]["update_frequency"]
        
        if expected_frequency == "daily" and age_days > 7:
            freshness = "stale"
        elif expected_frequency == "monthly" and age_days > 90:
            freshness = "stale"
        elif expected_frequency == "rarely" and age_days > 1825:  # 5 years
            freshness = "stale"
        else:
            freshness = "fresh"
        
        return {
            "status": freshness,
            "age_days": age_days,
            "expected_frequency": expected_frequency,
            "needs_verification": freshness == "stale"
        }
    
    def _identify_uncertainty_factors(self, key: str, entry: Dict[str, Any]) -> List[str]:
        """Identify factors that increase uncertainty about this knowledge"""
        
        factors = []
        
        # Low validation score
        if entry["validation_score"] < 0.6:
            factors.append("low_validation_score")
        
        # Multiple revisions suggest uncertainty
        if entry["revision_count"] > 3:
            factors.append("frequently_revised")
        
        # Conflicts present
        if self._check_for_conflicts(key):
            factors.append("conflicting_information")
        
        # Stale information
        freshness = self._assess_freshness(key, entry)
        if freshness["status"] == "stale":
            factors.append("outdated_information")
        
        # Single source
        if len(entry["source_nodes"]) == 1:
            factors.append("single_source")
        
        return factors
    
    def _check_consensus(self, proposal_id: str) -> Dict[str, Any]:
        """Check if consensus has been reached on a proposal"""
        
        proposal = self.pending_revisions[proposal_id]
        votes = proposal["votes"]
        
        total_votes = sum(len(vote_list) for vote_list in votes.values())
        
        if total_votes == 0:
            return {"reached": False, "reason": "no_votes"}
        
        support_ratio = len(votes["support"]) / total_votes
        oppose_ratio = len(votes["oppose"]) / total_votes
        
        threshold = self.conflict_resolution["version_conflicts"]["threshold"]
        
        if support_ratio >= threshold:
            return {"reached": True, "action": "approve_revision"}
        elif oppose_ratio >= threshold:
            return {"reached": True, "action": "reject_revision"}
        else:
            return {"reached": False, "reason": "insufficient_consensus"}
    
