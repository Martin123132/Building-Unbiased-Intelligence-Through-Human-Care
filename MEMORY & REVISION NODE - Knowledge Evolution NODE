    def _analyze_confidence_distribution(self) -> Dict[str, float]:
        """Analyze distribution of confidence levels"""
        
        if not self.knowledge_store:
            return {"high": 0, "medium": 0, "low": 0}
        
        high_conf = sum(1 for entry in self.knowledge_store.values() if entry["confidence"] >= 0.8)
        medium_conf = sum(1 for entry in self.knowledge_store.values() if 0.5 <= entry["confidence"] < 0.8)
        low_conf = sum(1 for entry in self.knowledge_store.values() if entry["confidence"] < 0.5)
        
        total = len(self.knowledge_store)
        
        return {
            "high_confidence": high_conf / total,
            "medium_confidence": medium_conf / total,
            "low_confidence": low_conf / total
        }
    
    def _identify_disputed_topics(self) -> List[Dict[str, Any]]:
        """Identify topics with the most disputes/revisions"""
        
        disputed = []
        
        for key, history in self.revision_history.items():
            if len(history) > 2:  # More than original + 1 revision
                disputed.append({
                    "topic": key,
                    "revision_count": len(history) - 1,
                    "current_confidence": self.knowledge_store[key]["confidence"]
                })
        
        return sorted(disputed, key=lambda x: x["revision_count"], reverse=True)[:5]
    
    def _analyze_knowledge_freshness(self) -> Dict[str, Any]:
        """Analyze how fresh the knowledge base is"""
        
        if not self.knowledge_store:
            return {"fresh": 0, "stale": 0, "very_stale": 0}
        
        now = datetime.now()
        fresh = stale = very_stale = 0
        
        for entry in self.knowledge_store.values():
            last_verified = datetime.fromisoformat(entry["last_verified"])
            age_days = (now - last_verified).days
            
            if age_days <= 30:
                fresh += 1
            elif age_days <= 365:
                stale += 1
            else:
                very_stale += 1
        
        total = len(self.knowledge_store)
        
        return {
            "fresh_percent": fresh / total * 100,
            "stale_percent": stale / total * 100,
            "very_stale_percent": very_stale / total * 100
        }
    
    def _assess_network_health(self) -> Dict[str, Any]:
        """Assess overall health of the knowledge network"""
        
        confidence_dist = self._analyze_confidence_distribution()
        freshness = self._analyze_knowledge_freshness()
        
        # Simple health score
        health_score = (
            confidence_dist["high_confidence"] * 0.4 +
            confidence_dist["medium_confidence"] * 0.3 +
            freshness["fresh_percent"] / 100 * 0.3
        )
        
        return {
            "overall_health_score": health_score,
            "status": "healthy" if health_score > 0.7 else "needs_attention" if health_score > 0.4 else "poor",
            "active_conflicts": len(self.pending_revisions),
            "consensus_functioning": len([p for p in self.pending_revisions.values() if p["status"] == "pending"]) < 10
        }
    
