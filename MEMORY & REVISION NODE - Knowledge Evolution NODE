    def store_knowledge(self, key: str, content: Any, metadata: Dict[str, Any]) -> str:
        """
        Store knowledge with full revision tracking and metadata.
        Returns version hash for this storage event.
        """
        
        timestamp = datetime.now().isoformat()
        version_hash = self._generate_version_hash(key, content, timestamp)
        
        # Create knowledge entry
        knowledge_entry = {
            "content": content,
            "metadata": metadata,
            "timestamp": timestamp,
            "version": version_hash,
            "confidence": metadata.get("confidence", 0.5),
            "source_nodes": metadata.get("source_nodes", [self.node_id]),
            "validation_score": self._calculate_validation_score(metadata),
            "last_verified": timestamp,
            "access_count": 0,
            "revision_count": 0
        }
        
        # Store or update
        if key not in self.knowledge_store:
            self.knowledge_store[key] = knowledge_entry
            self.revision_history[key] = [knowledge_entry.copy()]
        else:
            # Create revision
            old_entry = self.knowledge_store[key].copy()
            self.knowledge_store[key] = knowledge_entry
            self.revision_history[key].append(knowledge_entry.copy())
            
            # Log the revision
            self._log_revision(key, old_entry, knowledge_entry, RevisionType.UPDATE)
        
        return version_hash
    
    def propose_revision(self, key: str, new_content: Any, revision_type: RevisionType, 
                        justification: str, proposer_id: str) -> str:
        """
        Propose a revision to existing knowledge.
        Returns proposal ID for tracking.
        """
        
        if key not in self.knowledge_store:
            raise ValueError(f"Cannot revise non-existent knowledge: {key}")
        
        proposal_id = self._generate_proposal_id(key, proposer_id)
        
        proposal = {
            "key": key,
            "current_content": self.knowledge_store[key]["content"],
            "proposed_content": new_content,
            "revision_type": revision_type.value,
            "justification": justification,
            "proposer_id": proposer_id,
            "timestamp": datetime.now().isoformat(),
            "votes": {"support": [], "oppose": [], "abstain": []},
            "evidence": [],
            "status": "pending",
            "discussion": []
        }
        
        self.pending_revisions[proposal_id] = proposal
        
        # Notify relevant nodes
        self._notify_stakeholders(key, proposal_id)
        
        return proposal_id
    
    def vote_on_revision(self, proposal_id: str, voter_id: str, vote: str, 
                        reasoning: str = "") -> Dict[str, Any]:
        """
        Vote on a pending revision. Returns current vote status.
        """
        
        if proposal_id not in self.pending_revisions:
            raise ValueError(f"Proposal not found: {proposal_id}")
        
        proposal = self.pending_revisions[proposal_id]
        
        # Remove any previous vote by this voter
        for vote_type in proposal["votes"]:
            if voter_id in proposal["votes"][vote_type]:
                proposal["votes"][vote_type].remove(voter_id)
        
        # Add new vote
        if vote in proposal["votes"]:
            proposal["votes"][vote].append(voter_id)
            
            # Log reasoning if provided
            if reasoning:
                proposal["discussion"].append({
                    "voter_id": voter_id,
                    "vote": vote,
                    "reasoning": reasoning,
                    "timestamp": datetime.now().isoformat()
                })
        
        # Check if consensus reached
        consensus_result = self._check_consensus(proposal_id)
        
        return {
            "proposal_id": proposal_id,
            "current_votes": proposal["votes"],
            "consensus_reached": consensus_result["reached"],
            "action": consensus_result.get("action", "continue_voting")
        }
    
    def get_knowledge_with_confidence(self, key: str) -> Dict[str, Any]:
        """
        Retrieve knowledge with current confidence level and uncertainty factors.
        """
        
        if key not in self.knowledge_store:
            return {
                "found": False,
                "content": None,
                "confidence": 0.0,
                "explanation": "Knowledge not found in network"
            }
        
        entry = self.knowledge_store[key]
        
        # Calculate current confidence (may decay over time)
        current_confidence = self._calculate_current_confidence(key, entry)
        
        # Check for conflicting information
        conflicts = self._check_for_conflicts(key)
        
        # Assess freshness
        freshness = self._assess_freshness(key, entry)
        
        return {
            "found": True,
            "content": entry["content"],
            "confidence": current_confidence,
            "original_confidence": entry["confidence"],
            "validation_score": entry["validation_score"],
            "last_verified": entry["last_verified"],
            "revision_count": entry["revision_count"],
            "conflicts": conflicts,
            "freshness": freshness,
            "source_nodes": entry["source_nodes"],
            "uncertainty_factors": self._identify_uncertainty_factors(key, entry)
        }
    
    def sync_with_peer(self, peer_node_id: str, peer_knowledge: Dict[str, Any]) -> Dict[str, Any]:
        """
        Synchronize knowledge with a peer node, handling conflicts and updates.
        """
        
        sync_result = {
            "updates_received": 0,
            "updates_sent": 0,
            "conflicts_detected": 0,
            "consensus_items": 0,
            "timestamp": datetime.now().isoformat()
        }
        
        # Compare knowledge stores
        for key, peer_entry in peer_knowledge.items():
            if key not in self.knowledge_store:
                # New knowledge from peer
                if self._validate_peer_knowledge(peer_entry):
                    self.store_knowledge(key, peer_entry["content"], peer_entry["metadata"])
                    sync_result["updates_received"] += 1
            else:
                # Check for conflicts or updates
                conflict_result = self._resolve_knowledge_conflict(key, peer_entry)
                
                if conflict_result["action"] == "update_local":
                    self.store_knowledge(key, peer_entry["content"], peer_entry["metadata"])
                    sync_result["updates_received"] += 1
                elif conflict_result["action"] == "conflict":
                    sync_result["conflicts_detected"] += 1
                    # Flag for manual resolution
                    self._flag_conflict(key, peer_node_id, peer_entry)
        
        # Send our updates to peer (would be handled by peer's sync method)
        sync_result["peer_node"] = peer_node_id
        
        return sync_result
    
