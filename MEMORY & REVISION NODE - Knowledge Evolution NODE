    def _validate_peer_knowledge(self, peer_entry: Dict[str, Any]) -> bool:
        """Validate knowledge received from peer node"""
        
        required_fields = ["content", "metadata", "timestamp", "confidence"]
        
        for field in required_fields:
            if field not in peer_entry:
                return False
        
        # Check confidence is reasonable
        if not 0 <= peer_entry["confidence"] <= 1:
            return False
        
        return True
    
    def _resolve_knowledge_conflict(self, key: str, peer_entry: Dict[str, Any]) -> Dict[str, Any]:
        """Resolve conflict between local and peer knowledge"""
        
        local_entry = self.knowledge_store[key]
        
        # Compare validation scores
        local_validation = local_entry["validation_score"]
        peer_validation = peer_entry.get("validation_score", 0.5)
        
        # Compare timestamps
        local_time = datetime.fromisoformat(local_entry["timestamp"])
        peer_time = datetime.fromisoformat(peer_entry["timestamp"])
        
        # Simple resolution strategy
        if peer_validation > local_validation + 0.1:
            return {"action": "update_local", "reason": "higher_validation"}
        elif peer_time > local_time and abs(peer_validation - local_validation) < 0.1:
            return {"action": "update_local", "reason": "more_recent"}
        elif local_entry["content"] != peer_entry["content"]:
            return {"action": "conflict", "reason": "content_mismatch"}
        else:
            return {"action": "no_change", "reason": "equivalent"}
    
