from enum import Enum

class ValidationStatus(Enum):
    SUBMITTED = "submitted"
    UNDER_REVIEW = "under_review"
    PARADOX_TESTED = "paradox_tested"
    CROSS_REFERENCED = "cross_referenced"
    ACCEPTED_PROVISIONAL = "accepted_provisional"
    ACCEPTED_VERIFIED = "accepted_verified"
    REJECTED_CONTRADICTORY = "rejected_contradictory"
    REJECTED_INSUFFICIENT = "rejected_insufficient"
    NEEDS_REFINEMENT = "needs_refinement"

@dataclass
class TheorySubmission:
    theory_id: str
    title: str
    author: str
    content: str
    mathematical_framework: Optional[str]
    supporting_evidence: List[str]
    testable_predictions: List[str]
    submission_date: float
    status: ValidationStatus
    review_notes: List[str]
    cross_references: List[str]
    contradiction_reports: List[str]
    confidence_score: float

