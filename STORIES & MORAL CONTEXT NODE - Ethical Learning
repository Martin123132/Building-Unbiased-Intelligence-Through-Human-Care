    def _identify_story_patterns(self, scenario: str) -> List[str]:
        """Identify which story patterns match the scenario"""
        patterns = []
        scenario_lower = scenario.lower()
        
        if any(word in scenario_lower for word in ["rule", "law", "regulation", "policy"]):
            patterns.append("rule_breaking_dilemma")
        
        if any(word in scenario_lower for word in ["sacrifice", "give up", "cost", "loss"]):
            patterns.append("sacrifice_scenario")
        
        if any(word in scenario_lower for word in ["loyal", "betray", "friend", "trust"]):
            patterns.append("loyalty_conflict")
        
        if any(word in scenario_lower for word in ["power", "authority", "control", "leadership"]):
            patterns.append("power_responsibility")
        
        return patterns
    
    def _find_character_parallels(self, scenario: str, context: Dict[str, Any]) -> List[Dict[str, Any]]:
        """Find character archetypes that parallel the scenario"""
        parallels = []
        
        # Analyze scenario for character types
        if context.get("reluctant_responsibility"):
            parallels.append({
                "archetype": "reluctant_hero",
                "examples": self.character_archetypes["the_reluctant_hero"]["examples"],
                "relevance": "Character must accept unwanted responsibility"
            })
        
        if context.get("authority_figure_corrupt"):
            parallels.append({
                "archetype": "corrupt_authority", 
                "examples": self.character_archetypes["the_corrupt_authority"]["examples"],
                "relevance": "Dealing with abuse of power"
            })
        
        return parallels
    
    def _apply_narrative_frameworks(self, scenario: str, context: Dict[str, Any]) -> Dict[str, Any]:
        """Apply narrative moral frameworks to analyze the scenario"""
        
        applicable_frameworks = {}
        
        for framework_name, framework in self.narrative_frameworks.items():
            if self._framework_applies_to_scenario(framework, scenario, context):
                applicable_frameworks[framework_name] = {
                    "description": framework["description"],
                    "moral_principle": framework["moral_principle"],
                    "complexity_factors": framework["complexity_factors"],
                    "teaching_value": framework["teaching_value"]
                }
        
        return applicable_frameworks
    
    def _framework_applies_to_scenario(self, framework: Dict[str, Any], 
                                     scenario: str, context: Dict[str, Any]) -> bool:
        """Check if a narrative framework applies to the scenario"""
        
        framework_keywords = {
            "heroic_rule_breaking": ["rule", "law", "break", "illegal", "forbidden"],
            "sacrifice_and_redemption": ["sacrifice", "give up", "cost", "redemption"],
            "moral_ambiguity": ["difficult", "unclear", "competing", "complex"]
        }
        
        keywords = framework_keywords.get(framework.get("key", ""), [])
        return any(word in scenario.lower() for word in keywords)
    
    def _extract_moral_insights(self, scenario: str, story_patterns: List[str], 
                               character_parallels: List[Dict[str, Any]]) -> List[str]:
        """Extract moral insights from the analysis"""
        
        insights = []
        
        if "rule_breaking_dilemma" in story_patterns:
            insights.append("Sometimes doing the right thing requires breaking unjust rules")
            insights.append("Consider whether the rule serves a good purpose or protects the powerful")
        
        if "sacrifice_scenario" in story_patterns:
            insights.append("True moral courage often involves personal cost")
            insights.append("Distinguish between meaningful sacrifice and unnecessary martyrdom")
        
        for parallel in character_parallels:
            archetype_lessons = self.character_archetypes.get(parallel["archetype"], {}).get("moral_lessons", [])
            insights.extend(archetype_lessons)
        
        return list(set(insights))  # Remove duplicates
    
    def _analyze_multiple_perspectives(self, scenario: str) -> Dict[str, Any]:
        """Analyze scenario from multiple moral perspectives"""
        
        return {
            "utilitarian": "Focus on consequences and greatest good for greatest number",
            "deontological": "Focus on duties, rules, and inherent rightness of actions",
            "virtue_ethics": "Focus on character virtues and what a virtuous person would do",
            "care_ethics": "Focus on relationships, care, and emotional considerations",
            "narrative_ethics": "Focus on the story being told and its meaning for identity"
        }
    
    def _assess_ethical_complexity(self, scenario: str) -> str:
        """Assess the level of ethical complexity in the scenario"""
        
        complexity_indicators = {
            "simple": ["clear right/wrong", "obvious", "straightforward"],
            "medium": ["competing values", "multiple stakeholders", "unclear consequences"],
            "complex": ["systemic issues", "cultural differences", "long-term implications", "power dynamics"]
        }
        
        scenario_lower = scenario.lower()
        
        for level, indicators in complexity_indicators.items():
            if any(indicator in scenario_lower for indicator in indicators):
                return level
        
        return "medium"  # default
    
    def _suggest_teaching_applications(self, moral_insights: List[str]) -> List[str]:
        """Suggest how the insights could be used for teaching"""
        
