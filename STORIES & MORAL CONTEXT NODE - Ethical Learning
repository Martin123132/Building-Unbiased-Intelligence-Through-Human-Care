    def assess_story_contribution(self, story_data: Dict[str, Any], contributor_info: Dict[str, Any]) -> Dict[str, Any]:
        """
        Assess whether a story contribution meets guidelines and adds value.
        """
        
        assessment = {
            "copyright_compliant": False,
            "content_appropriate": False,
            "educational_value": False,
            "properly_attributed": False,
            "overall_assessment": "rejected",
            "feedback": []
        }
        
        # Check copyright compliance
        copyright_status = story_data.get("copyright_status", "unknown")
        if copyright_status in ["public_domain", "author_contributed", "community_original"]:
            assessment["copyright_compliant"] = True
        else:
            assessment["feedback"].append("Copyright status unclear or problematic")
        
        # Check content appropriateness
        if self._assess_content_appropriateness(story_data):
            assessment["content_appropriate"] = True
        else:
            assessment["feedback"].append("Content may not meet community standards")
        
        # Check educational value
        if story_data.get("moral_lessons") and len(story_data["moral_lessons"]) > 0:
            assessment["educational_value"] = True
        else:
            assessment["feedback"].append("Moral lessons or educational value not clear")
        
        # Check attribution
        if self._check_proper_attribution(story_data, contributor_info):
            assessment["properly_attributed"] = True
        else:
            assessment["feedback"].append("Attribution information incomplete")
        
        # Overall assessment
        if all([assessment["copyright_compliant"], assessment["content_appropriate"], 
                assessment["educational_value"], assessment["properly_attributed"]]):
            assessment["overall_assessment"] = "accepted"
            assessment["feedback"] = ["Story meets all guidelines and adds educational value"]
        elif assessment["copyright_compliant"] and assessment["content_appropriate"]:
            assessment["overall_assessment"] = "needs_revision"
            assessment["feedback"].append("Minor revisions needed before acceptance")
        
        return assessment
    
