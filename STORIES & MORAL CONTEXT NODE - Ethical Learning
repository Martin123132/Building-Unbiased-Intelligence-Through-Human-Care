    def analyze_moral_scenario(self, scenario: str, context: Dict[str, Any]) -> Dict[str, Any]:
        """
        Analyze a moral scenario using narrative frameworks and character insights.
        """
        
        # Identify relevant story patterns
        story_patterns = self._identify_story_patterns(scenario)
        
        # Find similar character archetypes
        character_parallels = self._find_character_parallels(scenario, context)
        
        # Apply narrative moral frameworks
        framework_analysis = self._apply_narrative_frameworks(scenario, context)
        
        # Extract moral lessons
        moral_insights = self._extract_moral_insights(scenario, story_patterns, character_parallels)
        
        # Consider multiple perspectives
        perspective_analysis = self._analyze_multiple_perspectives(scenario)
        
        return {
            "scenario": scenario,
            "story_patterns": story_patterns,
            "character_parallels": character_parallels,
            "narrative_frameworks": framework_analysis,
            "moral_insights": moral_insights,
            "multiple_perspectives": perspective_analysis,
            "ethical_complexity": self._assess_ethical_complexity(scenario),
            "teaching_applications": self._suggest_teaching_applications(moral_insights),
            "source_node": self.node_id,
            "domain": self.domain
        }
    
    def find_relevant_stories(self, moral_question: str, complexity_level: str = "any") -> List[Dict[str, Any]]:
        """
        Find stories that illuminate a particular moral question.
        """
        
        relevant_stories = []
        
        # Search through story collection
        for category, stories in self.story_collection.items():
            for story_id, story_data in stories.items():
                if self._story_addresses_question(story_data, moral_question, complexity_level):
                    relevant_stories.append({
                        "story_id": story_id,
                        "category": category,
                        "title": story_data.get("story_title", story_id),
                        "moral_lessons": story_data["moral_lessons"],
                        "themes": [theme.value for theme in story_data["themes"]],
                        "complexity": story_data["complexity_level"],
                        "relevance_score": self._calculate_relevance_score(story_data, moral_question),
                        "copyright_status": story_data["copyright_status"]
                    })
        
        # Sort by relevance
        relevant_stories.sort(key=lambda x: x["relevance_score"], reverse=True)
        
        return relevant_stories
    
